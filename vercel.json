{
    "version": 2,
    "buildCommand": "cd frontend && npm run build",
    "outputDirectory": "frontend/dist",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.php"
        },
        {
            "source": "/storage/(.*)",
            "destination": "/backend/public/storage/$1"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/frontend/assets/$1"
        },
        {
            "source": "/vite.svg",
            "destination": "/frontend/vite.svg"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/index.html"
        }
    ]
}
