{
    "version": 2,
    "buildCommand": "cd frontend && npm run build",
    "outputDirectory": "frontend/dist",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0",
            "includeFiles": "backend/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.php"
        },
        {
            "source": "/storage/(.*)",
            "destination": "/api/index.php"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
