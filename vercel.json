{
    "version": 2,
    "buildCommand": "cd frontend && npm run build",
    "outputDirectory": "frontend/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://empang-v2.onrender.com/api/$1"
        },
        {
            "source": "/storage/(.*)",
            "destination": "https://empang-v2.onrender.com/storage/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
